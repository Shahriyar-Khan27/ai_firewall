# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
*.spec
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
.venv-*/
venv/
env/
ENV/

# --- VS Code extension build artifacts ---
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix
vscode-extension/.vscode-test/

# --- Editor / OS ---
.idea/
*.swp
.DS_Store
Thumbs.db
# Atomic-write scratch files left behind when an editor process crashes
# mid-rename (Windows VS Code, JetBrains, etc.). Glob deliberately broad.
*.tmp.*

# --- Runtime artifacts ---
# Audit logs are runtime data, not source.
logs/

# --- Local secrets / overrides ---
.env
.env.*
local_rules.yaml
